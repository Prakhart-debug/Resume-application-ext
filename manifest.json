{
  "manifest_version": 3,
  "name": "Resume Tailor",
  "version": "1.0",
  "description": "Tailor your resume and generate a cover letter from LinkedIn/Indeed job descriptions using Claude AI.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.accenture.com/*",
    "https://latexonline.cc/*"
  ],
  "web_accessible_resources": [{
    "resources": ["base-resume.txt", "resume-template.tex"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Resume Tailor"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.indeed.com/viewjob*",
        "https://www.accenture.com/*/careers/jobdetails*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "settings.html"
}
